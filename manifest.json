{
  "manifest_version": 3,
  "name": "DeepGuard — Deepfake Detector",
  "version": "1.0.0",
  "description": "Real-time deepfake, AI avatar, and synthetic video detection for Google Meet calls.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "offscreen",
    "sidePanel"
  ],
  "host_permissions": [
    "https://meet.google.com/*"
  ],
  "background": {
    "service_worker": "dist/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["dist/content/index.js"],
      "css": ["dist/content/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "DeepGuard"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "dist/offscreen/index.js",
        "offscreen/index.html",
        "models/*.onnx",
        "models/face_landmarker.task",
        "models/deepfake_classifier.json",
        "dist/content/overlay.css",
        "*.wasm",
        "mediapipe/*",
        "dist/shared/*.js"
      ],
      "matches": ["https://meet.google.com/*", "chrome-extension://*/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
